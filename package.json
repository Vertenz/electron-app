{
  "name": "electron-app",
  "version": "1.0.0",
  "description": "",
  "homepage": "https://github.com/Vertenz/electron-app#readme",
  "bugs": {
    "url": "https://github.com/Vertenz/electron-app/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vertenz/electron-app.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "prepare": "husky",
    "lint": "eslint --cache --fix .",
    "format": "prettier --write . --ignore-unknown",
    "check": "eslint . && prettier --check . --ignore-unknown",
    "lint:all": "npm run lint && npm run format",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{ts,tsx,mts,js,mjs,cjs}": [
      "eslint --cache --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md,yaml,yml,html}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "electron": "^41.5.0",
    "electron-devtools-installer": "^4.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "makers": [
    {
      "name": "@electron-forge/maker-squirrel",
      "config": {
        "name": "electron_quick_start"
      }
    },
    {
      "name": "@electron-forge/maker-zip",
      "platforms": [
        "darwin"
      ]
    },
    {
      "name": "@electron-forge/maker-deb",
      "config": {}
    },
    {
      "name": "@electron-forge/maker-rpm",
      "config": {}
    }
  ],
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  }
}
